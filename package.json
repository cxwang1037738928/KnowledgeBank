{
  "name": "bookwyrm",
  "version": "1.0.0",
  "description": "Intelligent document retrieval with RAG and cosine similarity search",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node --watch backend/server.js",
    "install:py": ".venv\\Scripts\\python.exe -m pip install -r backend/extraction/requirements.txt",
    "test:clean": "node tests/test_cleaning.js",
    "test:extract": "node tests/test_extract.js",
    "test:embed": "node tests/test_embed.js",
    "test:chunking": "node tests/test_chunking.js",
    "test:generate-categories": "node tests/test_generate_categories.js",
    "test:heuristic": "node tests/test_heuristic.js",
    "test:build-graph": "node tests/test_build_graph.js",
    "test:pipeline": "node tests/test_extract.js && node tests/test_embed.js && node tests/test_generate_categories.js && node tests/test_heuristic.js && node tests/test_build_graph.js"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@xenova/transformers": "^2.17.2",
    "bullmq": "^5.79.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^6.1.200",
    "sharp": "^0.35.2"
  }
}
