{
  "name": "opencrawl",
  "version": "1.0.0",
  "description": "Intelligent document retrieval with RAG and cosine similarity search",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "start:test": "cross-env DATA_DIR=tests/test-output node backend/server.js",
    "dev": "node --watch-path=backend backend/server.js",
    "dev:test": "cross-env DATA_DIR=tests/test-output node --watch-path=backend backend/server.js",
    "dev:web": "npm --prefix frontend run dev",
    "dev:all": "node scripts/dev.mjs",
    "build:web": "npm --prefix frontend run build",
    "install:web": "npm --prefix frontend install",
    "install:py": ".venv\\Scripts\\python.exe -m pip install --only-binary=:all: -r backend/extraction/requirements.txt",
    "test:clean": "node tests/test_cleaning.js",
    "test:extract": "node tests/test_extract.js",
    "test:embed": "node tests/test_embed.js",
    "test:chunking": "node tests/test_chunking.js",
    "test:generate-categories": "node tests/test_generate_categories.js",
    "test:heuristic": "node tests/test_heuristic.js",
    "test:build-graph": "node tests/test_kg_graph.js",
    "test:api": "node tests/test_api.js",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "test:pipeline": "node tests/test_extract.js && node tests/test_embed.js && node tests/test_generate_categories.js && node tests/test_heuristic.js && node tests/test_kg_graph.js",
    "fetch:model": "node scripts/fetch_model.mjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@prisma/client": "^6.19.3",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^6.1.200",
    "sharp": "^0.35.2",
    "umap-js": "^1.4.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "playwright": "^1.61.1",
    "prisma": "^6.19.3"
  }
}
